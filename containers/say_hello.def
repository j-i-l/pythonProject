Bootstrap: docker
From: python:3.13-slim

%files
    # Explicitly copy required directories
    pyproject.toml /app/
    src/ /app/src/
    scripts/ /app/scripts/
    
    # REQUIRED: Copy .git folder so we can extract the version
    .git/ /app/.git/

%post
    # 1. Install necessary system dependencies
    apt-get update && apt-get install -y git curl
    rm -rf /var/lib/apt/lists/*

    # 2. Install uv package manager
    curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR="/bin" sh

    # 3. Configure Git to trust the mounted directory
    cd /app
    git config --global --add safe.directory /app

    # 4. Extract version and inject it into the environment
    # By exporting this variable, hatch-vcs will completely ignore the missing .git 
    # folder during the isolated build phase in /tmp/
    uv pip install --system setuptools-scm
    export SETUPTOOLS_SCM_PRETEND_VERSION=$(python -m setuptools_scm)

    # 5. Install the project normally (build isolation will now succeed)
    uv pip install --system --no-cache --compile-bytecode .

%runscript
    # 6. Define the execution behavior
    cd /app
    exec python scripts/drafts/hello.py "$@"
