Bootstrap: docker
From: python:3.13-slim

%arguments
    VERSION

%files
    pyproject.toml /app/
    LICENSE /app/
    README.md /app/
    src /app/src
    scripts/drafts/say_hello.py /app/scripts/drafts/say_hello.py

%post
    # 1. System updates (Git is no longer strictly required here!)
    apt-get update && apt-get install -y curl
    rm -rf /var/lib/apt/lists/*

    # 2. Install uv
    curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR="/bin" sh

    # 3. Build and Install
    cd /app
    
    # Inject the version and suppress filesystem warnings
    export SETUPTOOLS_SCM_PRETEND_VERSION="{{ VERSION }}"
    export UV_LINK_MODE=copy
    
    uv pip install --system --no-cache --compile-bytecode .

%runscript
    cd /app
    exec python scripts/drafts/say_hello.py "$@"
