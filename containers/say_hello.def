Bootstrap: docker
From: python:3.13-slim

%files
    # Explicitly copy required directories
    pyproject.toml /app/
    src/ /app/src/
    scripts/ /app/scripts/
    
    # REQUIRED BY HATCHLING: Copy .git folder for dynamic versioning
    .git/ /app/.git/

%post
    # 1. Install necessary system dependencies
    apt-get update && apt-get install -y git curl
    rm -rf /var/lib/apt/lists/*

    # 2. Install uv package manager
    curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR="/bin" sh

    # 3. Configure Git to trust the mounted directory
    git config --global --add safe.directory /app

    # 4. Install the project utilizing uv
    cd /app
    
    # FIX: Bypass isolated build directories so hatch-vcs can locate the .git root.
    # Pre-install the build backend, then install the project without isolation.
    uv pip install --system hatchling hatch-vcs
    uv pip install --system --no-build-isolation --no-cache --compile-bytecode .

%runscript
    # 5. Define the execution behavior
    cd /app
    exec python scripts/drafts/hello.py "$@"
