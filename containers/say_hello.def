Bootstrap: docker
From: python:3.13-slim

%files
    # Explicitly copy required directories
    pyproject.toml /app/
    LICENSE /app/
    README.md /app/
    src /app/src
    scripts/drafts/say_hello.py /app/scripts/drafts/say_hello.py
    .git /app/.git

%post
    # 1. Install necessary system dependencies
    apt-get update && apt-get install -y git curl
    rm -rf /var/lib/apt/lists/*

    # 2. Install uv package manager
    curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR="/bin" sh

    # 3. Configure Git to trust the mounted directory
    cd /app
    git config --system --add safe.directory /app

    # 5. Install the project utilizing uv
    uv pip install --system --no-cache --compile-bytecode .

%runscript
    # 6. Define the execution behavior
    cd /app
    exec python scripts/drafts/say_hello.py "$@"
